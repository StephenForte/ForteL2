# ForteL2 Phase 2 (Sepolia) — operator-local only.
# Copy to .env.sepolia and fill addresses + keys OFFLINE.
# Never commit .env.sepolia. Never paste private keys into agent chat.
#
# Load with:  FORTEL2_ENV=.env.sepolia ./scripts/...
# Phase 1 (.env / chain 901) stays untouched.

# --- Paths ---
FORTEL2_ROOT=/Users/steveforte/ForteL2
BIN_DIR=/Users/steveforte/ForteL2/bin
# Separate datadir from Phase 1 Anvil stack
DATA_DIR=/Users/steveforte/src/fortel2/data-sepolia
DEPLOY_DIR=/Users/steveforte/ForteL2/deployments/sepolia/.deployer

# --- Chain IDs ---
# Ethereum Sepolia L1; private learning L2 (not a public chain id)
L1_CHAIN_ID=11155111
L2_CHAIN_ID=852

# --- L1 RPC (Phase 2d: QuickNode HTTPS; same var, no redeploy) ---
# Use a Mac-mini-only QuickNode endpoint here. Render replica gets a *separate*
# endpoint URL in fortel2-replica Render secrets (never share the same token).
# Public (rate-limited) examples for smoke only:
#   https://ethereum-sepolia-rpc.publicnode.com
#   https://rpc.sepolia.org
# QuickNode: dashboard → Ethereum → Sepolia → copy HTTPS URL into L1_RPC_URL locally
L1_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Optional until blob DA / leaving beacon-ignore; not required for Phase 2d
# L1_BEACON_URL=

# --- L2 stays loopback (US-012 non-loopback still no-go) ---
L1_BLOCK_TIME=12
L2_BLOCK_TIME=2
L2_EL_HTTP_PORT=9545
L2_EL_WS_PORT=9546
L2_EL_AUTH_PORT=9551
L2_NODE_RPC_PORT=9547
L2_RPC_URL=http://127.0.0.1:9545
L2_NODE_RPC_URL=http://127.0.0.1:9547
DAPP_HTTP_PORT=8080
VIEWER_HTTP_PORT=8081
# Shared with Phase 1 defaults — cannot run both stacks at once
BATCHER_RPC_PORT=8548
PROPOSER_RPC_PORT=8560

# --- Harvest wallet (funded; never a signer for deploy/batcher/proposer) ---
HARVEST_ADDRESS=0x5128889F20Ec13e0Be38b2BeBC568594159B652d

# --- Fresh Sepolia roles (generate offline with: cast wallet new) ---
# Fill ADDRESS fields in the committed example copy; PRIVATE_KEY only in local .env.sepolia
ADMIN_ADDRESS=
ADMIN_PRIVATE_KEY=
BATCHER_ADDRESS=
BATCHER_PRIVATE_KEY=
PROPOSER_ADDRESS=
PROPOSER_PRIVATE_KEY=
SEQUENCER_ADDRESS=
SEQUENCER_PRIVATE_KEY=
CHALLENGER_ADDRESS=
CHALLENGER_PRIVATE_KEY=

# Optional L2 demo wallets (fund via bridge in Phase 2c — no genesis fundDevAccounts)
# DEMO_A_ADDRESS=
# DEMO_A_PRIVATE_KEY=
# DEMO_B_ADDRESS=
# DEMO_B_PRIVATE_KEY=

# --- Batcher / proposer (credit-budget defaults for metered L1 RPC) ---
BATCHER_DA_TYPE=calldata
PROPOSER_GAME_TYPE=1
# Sepolia proposer cadence (script default 5m). Do NOT set Phase-1 PROPOSER_INTERVAL=12s
# here — 06-start-proposer-sepolia.sh ignores it and uses SEPOLIA_PROPOSER_INTERVAL only.
SEPOLIA_PROPOSER_INTERVAL=5m
# Optional overrides (scripts already default to these when unset):
# SEPOLIA_BATCHER_POLL_INTERVAL=12s
# SEPOLIA_BATCHER_MAX_CHANNEL_DURATION=30
# SEPOLIA_BATCHER_TXMGR_RECEIPT_QUERY_INTERVAL=24s
# SEPOLIA_BATCHER_TXMGR_REBROADCAST_INTERVAL=24s
# SEPOLIA_PROPOSER_POLL_INTERVAL=12s
# SEPOLIA_L1_HTTP_POLL_INTERVAL=12s
# SEPOLIA_L1_RPC_RATE_LIMIT=20
# Faster demo cadence (burns credits):
#   SEPOLIA_BATCHER_MAX_CHANNEL_DURATION=2 SEPOLIA_BATCHER_POLL_INTERVAL=2s SEPOLIA_PROPOSER_INTERVAL=12s

# --- Learning-short portal delays (Phase 2b intent; mainnet is ~7d / ~3.5d) ---
PROOF_MATURITY_DELAY_SECONDS=12
DISPUTE_GAME_FINALITY_DELAY_SECONDS=6
# maxClockDuration must be >= clockExtension (op-deployer DeployImplementations)
FAULT_GAME_CLOCK_EXTENSION=5
FAULT_GAME_MAX_CLOCK_DURATION=10
FAULT_GAME_WITHDRAWAL_DELAY=1
