# ForteL2 Phase 1 — throwaway Anvil/Foundry keys ONLY. Never put real funds here.

# --- Paths (source builds + runtime data live outside Dropbox) ---
FORTEL2_ROOT=/Users/steveforte/ForteL2
BIN_DIR=/Users/steveforte/ForteL2/bin
# Runtime data (Anvil state, op-geth datadir, logs, pids) — NOT under Dropbox
DATA_DIR=/Users/steveforte/src/fortel2/data
DEPLOY_DIR=/Users/steveforte/ForteL2/deployments/.deployer

# --- Chain IDs (private; do not collide with public networks) ---
L1_CHAIN_ID=900
L2_CHAIN_ID=901

# --- RPCs / ports ---
L1_RPC_URL=http://127.0.0.1:8545
L1_RPC_PORT=8545
L2_EL_HTTP_PORT=9545
L2_EL_WS_PORT=9546
L2_EL_AUTH_PORT=9551
L2_NODE_RPC_PORT=9547
L2_RPC_URL=http://127.0.0.1:9545
L2_NODE_RPC_URL=http://127.0.0.1:9547
DAPP_HTTP_PORT=8080
VIEWER_HTTP_PORT=8081
# op-batcher / op-proposer admin RPC (loopback; shared Phase 1 + 2c — keep free together)
BATCHER_RPC_PORT=8548
PROPOSER_RPC_PORT=8560

# --- Timing ---
L1_BLOCK_TIME=2
L2_BLOCK_TIME=2

# --- Throwaway roles (Foundry/Anvil default mnemonic accounts) ---
# Account 0 — deployer / admin / vault recipient
ADMIN_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Account 1 — batcher
BATCHER_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
BATCHER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Account 2 — proposer
PROPOSER_ADDRESS=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
PROPOSER_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# Account 3 — sequencer (op-node p2p.sequencer.key / unsafe block signer)
SEQUENCER_ADDRESS=0x90F79bf6EB2c4f870365E785982E1f101E93b906
SEQUENCER_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# Account 4 — challenger (unused until Phase 7; still required by intent)
CHALLENGER_ADDRESS=0x15d34AAf54267DB7D7c367839AAf71A00a2C6A65
CHALLENGER_PRIVATE_KEY=0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926a

# Account 5 + 6 — extra genesis-funded L2 demo wallets (fundDevAccounts also funds 0–9)
DEMO_A_ADDRESS=0x9965507D1a55bcC2695C58ba16FB37d819B0A4dc
DEMO_A_PRIVATE_KEY=0x8b3a350cf5c34c9194ca85829a2df0ec3153be0318b5e2d3348e872092edffba
DEMO_B_ADDRESS=0x976EA74026E726554dB657fA54763abd0C3a0aa9
DEMO_B_PRIVATE_KEY=0x92db14e403b83dfe3df233f83dfa3a0d7096f21ca9b0d6d6b8d88b2b4ec1564e

# --- Batcher / proposer ---
# Anvil has no beacon/blobs → calldata DA + ignore beacon on op-node
BATCHER_DA_TYPE=calldata
PROPOSER_GAME_TYPE=1
PROPOSER_INTERVAL=12s

# --- Phase 1b bridge delays (op-deployer globalDeployOverrides; seconds) ---
# Mainnet uses ~7d proof maturity / ~3.5d dispute-game finality. Local learning defaults:
PROOF_MATURITY_DELAY_SECONDS=12
DISPUTE_GAME_FINALITY_DELAY_SECONDS=6
FAULT_GAME_MAX_CLOCK_DURATION=10
FAULT_GAME_WITHDRAWAL_DELAY=1

# Optional deposit/withdraw amounts
# DEPOSIT_AMOUNT=0.1ether
# WITHDRAW_AMOUNT=0.05ether

# --- Tooling pins (recorded at install time; update README when bumping) ---
# Go 1.26.5 | just 1.56.0 | yq 4.53.3 | Foundry 1.7.1
# optimism op-node/v1.19.2 (da197e45) | op-geth v1.101702.2 | op-deployer 0.7.1
