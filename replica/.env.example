# Copy to replica/.env for local compose (gitignored). On Render, set as secrets.
# Never commit real QuickNode URLs with tokens.

# Ethereum Sepolia HTTPS (Phase 2d QuickNode preferred)
L1_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Match Phase 2c sequencer (--l1.beacon.slot-duration-override); Sepolia ~12s.
L1_BLOCK_TIME=12

# Seconds to wait for op-geth IPC before failing the container. 0 = keep waiting
# while geth is alive (default; needed for archive datadir crash recovery).
# GETH_READY_TIMEOUT_SECS=0

# Optional: pin JWT across restarts (64 hex chars). Empty → generated into volume.
# JWT_SECRET=
